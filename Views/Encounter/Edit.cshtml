@model DnDManager.Models.Encounter

@{
    ViewData["Title"] = "Edit Encounter";
}

<h2>Edit Encounter</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" asp-for="EncounterId" />
            <input type="hidden" asp-for="SessionLogId" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="Outcome" class="form-label"></label>
                <input asp-for="Outcome" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Index" asp-route-sessionLogId="@Model.SessionLogId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
