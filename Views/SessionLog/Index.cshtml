@model List<DnDManager.Models.SessionLog>

@{
    ViewData["Title"] = "Session Logs";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Session Logs</h2>
    <div>
        <a asp-action="Create" asp-route-campaignId="@ViewBag.CampaignId" class="btn btn-primary btn-sm">+ Log Session</a>
        <a asp-controller="Campaign" asp-action="Details" asp-route-id="@ViewBag.CampaignId" class="btn btn-secondary btn-sm">Back to Campaign</a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No sessions logged yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>Date</th>
                    <th>Major Outcome</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td>@log.SessionNumber</td>
                        <td><strong>@log.Title</strong></td>
                        <td>@log.SessionDate.ToShortDateString()</td>
                        <td>@log.MajorOutcome</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@log.SessionLogId" class="btn btn-sm btn-info">View</a>
                            <a asp-action="Edit" asp-route-id="@log.SessionLogId" class="btn btn-sm btn-secondary">Edit</a>
                            @using (Html.BeginForm("Delete", "SessionLog", new { id = log.SessionLogId }, FormMethod.Post, null, new { style = "display:inline" }))
                            {
                                <button type="submit" class="btn btn-sm btn-danger"
                                        onclick="return confirm('Delete this session log?')">Delete</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}