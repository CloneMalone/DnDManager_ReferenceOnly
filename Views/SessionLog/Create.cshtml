@model DnDManager.Models.SessionLog

@{
    ViewData["Title"] = "Log Session";
}

<h2>Log Session</h2>

<div class="row">
    <div class="col-md-7">
        <form asp-action="Create" method="post">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" asp-for="CampaignId" value="@ViewBag.CampaignId" />

            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>
                <div class="col-auto mb-3">
                    <label asp-for="SessionNumber" class="form-label"></label>
                    <input asp-for="SessionNumber" class="form-control" style="width:80px" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="SessionDate" class="form-label"></label>
                <input asp-for="SessionDate" class="form-control" type="date" />
                <span asp-validation-for="SessionDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Summary" class="form-label"></label>
                <textarea asp-for="Summary" class="form-control" rows="4"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="MajorOutcome" class="form-label"></label>
                <input asp-for="MajorOutcome" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary">Save Session</button>
            <a asp-action="Index" asp-route-campaignId="@ViewBag.CampaignId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}