@model DnDManager.Models.Combatant

@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">@Model.Name</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.CombatantId" class="btn btn-secondary btn-sm">Edit</a>
        <a asp-action="Index" asp-route-campaignId="@Model.CampaignId" class="btn btn-outline-secondary btn-sm">Back to Tracker</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Type</dt>
            <dd class="col-sm-9">@Model.Type</dd>

            <dt class="col-sm-3">HP</dt>
            <dd class="col-sm-9">@Model.CurrentHP / @Model.MaxHP</dd>

            <dt class="col-sm-3">Armor Class</dt>
            <dd class="col-sm-9">@Model.ArmorClass</dd>

            <dt class="col-sm-3">Initiative</dt>
            <dd class="col-sm-9">@Model.Initiative</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <span class="badge @(Model.IsDefeated ? "bg-danger" : "bg-success")">
                    @(Model.IsDefeated ? "Defeated" : "Active")
                </span>
            </dd>
        </dl>
    </div>
</div>
