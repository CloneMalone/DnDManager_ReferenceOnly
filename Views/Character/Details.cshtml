@model DnDManager.Models.Character

@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">@Model.Name</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.CharacterId" class="btn btn-secondary btn-sm">Edit</a>
        <a asp-action="Index" asp-route-campaignId="@Model.CampaignId" class="btn btn-outline-secondary btn-sm">Back to Characters</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Class</dt>
            <dd class="col-sm-9">@Model.Class</dd>

            <dt class="col-sm-3">Race</dt>
            <dd class="col-sm-9">@Model.Race</dd>

            <dt class="col-sm-3">Level</dt>
            <dd class="col-sm-9">@Model.Level</dd>

            <dt class="col-sm-3">HP</dt>
            <dd class="col-sm-9">@Model.CurrentHP / @Model.MaxHP</dd>

            <dt class="col-sm-3">Armor Class</dt>
            <dd class="col-sm-9">@Model.AC</dd>

            <dt class="col-sm-3">Initiative Bonus</dt>
            <dd class="col-sm-9">@(Model.InitiativeBonus >= 0 ? "+" : "")@Model.InitiativeBonus</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><span class="badge @(Model.Status == "Active" ? "bg-success" : Model.Status == "Unconscious" ? "bg-warning text-dark" : "bg-danger")">@Model.Status</span></dd>
        </dl>
    </div>
</div>