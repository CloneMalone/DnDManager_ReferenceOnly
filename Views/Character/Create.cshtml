@model DnDManager.Models.Character

@{
    ViewData["Title"] = "Add Character";
}

<h2>Add Character</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" asp-for="CampaignId" value="@ViewBag.CampaignId" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Class" class="form-label"></label>
                    <input asp-for="Class" class="form-control" />
                </div>
                <div class="col mb-3">
                    <label asp-for="Race" class="form-label"></label>
                    <input asp-for="Race" class="form-control" />
                </div>
            </div>

            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Level" class="form-label"></label>
                    <input asp-for="Level" class="form-control" />
                    <span asp-validation-for="Level" class="text-danger"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="AC" class="form-label"></label>
                    <input asp-for="AC" class="form-control" />
                </div>
            </div>

            <div class="row">
                <div class="col mb-3">
                    <label asp-for="MaxHP" class="form-label"></label>
                    <input asp-for="MaxHP" class="form-control" />
                    <span asp-validation-for="MaxHP" class="text-danger"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="CurrentHP" class="form-label"></label>
                    <input asp-for="CurrentHP" class="form-control" />
                </div>
            </div>

            <div class="row">
                <div class="col mb-3">
                    <label asp-for="InitiativeBonus" class="form-label"></label>
                    <input asp-for="InitiativeBonus" class="form-control" />
                </div>
                <div class="col mb-3">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select">
                        <option value="Active">Active</option>
                        <option value="Unconscious">Unconscious</option>
                        <option value="Dead">Dead</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Save Character</button>
            <a asp-action="Index" asp-route-campaignId="@ViewBag.CampaignId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}